@model CarRental.ViewModels.SecuritySettingsViewModel

<h2 class="mb-4">Security Settings</h2>

@if (TempData["msg"] != null)
{
    <div class="alert alert-success">
        @TempData["msg"]
    </div>
}

<div asp-validation-summary="All" class="text-danger mb-3"></div>

<form asp-action="UserSettings" method="post">

    ```
    @Html.AntiForgeryToken()

    <div class="card shadow-sm p-4">

        <h5 class="mb-3">Brute Force Protection</h5>

        <div class="form-check mb-3">
            <input asp-for="EnableBruteForceProtection" class="form-check-input" />
            <label asp-for="EnableBruteForceProtection" class="form-check-label">
                Enable Brute Force Protection
            </label>
        </div>

        <div class="mb-3">
            <label asp-for="MaxLoginAttempts" class="form-label">
                Max Failed Login Attempts (IP)
            </label>
            <input asp-for="MaxLoginAttempts" class="form-control" min="1" max="20" />
            <span asp-validation-for="MaxLoginAttempts" class="text-danger"></span>
            <small class="text-muted">
                Number of failed login attempts before IP is temporarily blocked
            </small>
        </div>

        <div class="mb-3">
            <label asp-for="IpWindowMinutes" class="form-label">
                IP Attempt Window (minutes)
            </label>
            <input asp-for="IpWindowMinutes" class="form-control" min="1" max="60" />
            <span asp-validation-for="IpWindowMinutes" class="text-danger"></span>
            <small class="text-muted">
                Time window after which failed attempts reset
            </small>
        </div>

        <hr />

        <h5 class="mb-3">Account Lockout</h5>

        <div class="mb-3">
            <label asp-for="LockoutMinutes" class="form-label">
                Account Lock Duration (minutes)
            </label>
            <input asp-for="LockoutMinutes" class="form-control" min="1" max="1440" />
            <span asp-validation-for="LockoutMinutes" class="text-danger"></span>
            <small class="text-muted">
                Duration of account lock after too many failed attempts
            </small>
        </div>

        <hr />

        <h5 class="mb-3">Session Security</h5>

        <div class="mb-3">
            <label asp-for="SessionTimeoutMinutes" class="form-label">
                Session Timeout (minutes)
            </label>
            <input asp-for="SessionTimeoutMinutes" class="form-control" min="1" max="240" />
            <span asp-validation-for="SessionTimeoutMinutes" class="text-danger"></span>
            <small class="text-muted">
                User will be logged out after inactivity
            </small>
        </div>

        <button class="btn btn-primary mt-2">
            Save Security Settings
        </button>

    </div>
    ```

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
