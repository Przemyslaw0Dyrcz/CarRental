<h2 class="mb-4">Admin Dashboard</h2>

<div class="row g-3">

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Users</h5>
                <a asp-action="Index" class="btn btn-primary">Manage Users</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Security</h5>
                <a asp-action="SecurityDashboard" class="btn btn-danger">Security Dashboard</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Activity Logs</h5>
                <a asp-action="Logs" class="btn btn-secondary">View Logs</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Security Alerts</h5>
                <a asp-action="Alerts" class="btn btn-warning">Alerts</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Settings</h5>
                <a asp-action="UserSettings" class="btn btn-dark">Settings</a>
            </div>
        </div>
    </div>

</div>