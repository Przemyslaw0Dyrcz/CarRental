
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>CarRental</title>
</head>

<body class="bg-gray-50">

    <nav class="bg-white shadow mb-4">
        <div class="max-w-7xl mx-auto px-4">
            <div class="flex justify-between h-16 items-center">

                <a class="flex items-center gap-2 text-xl font-semibold"
                   asp-controller="Home" asp-action="Index">
                    <i class="bi bi-car-front"></i> CarRental
                </a>

                <div class="flex gap-6">

                    <a class="text-gray-700 hover:text-black"
                       asp-controller="Cars" asp-action="Index">Cars</a>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <a class="text-gray-700 hover:text-black"
                           asp-controller="Reservations" asp-action="My">My reservations</a>
                    }

                    @if (User.IsInRole("Dealer") || User.IsInRole("Admin"))
                    {
                        <a asp-controller="Dealer" asp-action="Dashboard">Dealer Panel</a>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <a class="text-gray-700 hover:text-black"
                           asp-controller="Admin"
                           asp-action="Dashboard">
                            Admin
                        </a>
                    }
                </div>

                <div class="flex items-center gap-4">

                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="relative group">
                            <button class="flex items-center gap-2 font-medium">
                                <i class="bi bi-person-circle"></i>
                                @User.Identity.Name
                            </button>

                            <div class="absolute right-0 hidden group-hover:block bg-white shadow rounded p-3">

                                <a class="block py-1"
                                   asp-controller="Account" asp-action="Profile">Profile</a>

                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()

                                    <button type="submit" class="block py-1 text-left w-full">
                                        Logout
                                    </button>
                                </form>

                            </div>
                        </div>
                    }
                    else
                    {
                        <a class="text-gray-700"
                           asp-controller="Account" asp-action="Login">Login</a>

                        <a class="bg-black text-white px-3 py-1 rounded"
                           asp-controller="Account" asp-action="Register">Register</a>
                    }

                </div>

            </div>
        </div>
    </nav>

    <div class="max-w-7xl mx-auto px-4">
        @RenderBody()
    </div>
    @RenderSection("Scripts", required: false)
</body>
</html>
